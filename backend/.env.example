# OAuth 2.0 Client Credentials
# Add your Google Client ID and Secret here
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Add your GitHub Client ID and Secret here
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# Frontend Application Deployment Origin (Crucial for Vercel deployment CORS & OAuth)
FRONTEND_URL=https://your-vercel-app-name.vercel.app

# Database URL (Optional: Defaults dynamically to SQLite. Use PostgreSQL for full production)
# DATABASE_URL=postgresql://user:password@hostname/dbname

# Session Secret (Required for FastAPI SessionMiddleware)
SESSION_SECRET=super_secret_session_string_2026

# SMTP Delivery Integrations (Google Gmail with Application Passwords works ideally)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
